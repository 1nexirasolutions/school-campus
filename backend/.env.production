# ===== Backend Production =====
# These should be set as environment variables on the hosting platform
# DO NOT commit real values to git

# MongoDB Atlas connection string (replace with your Atlas URI)
MONGO_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/schoolerp?retryWrites=true&w=majority

# Port (Railway/Render auto-sets this)
PORT=8000
